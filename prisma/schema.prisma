generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id            BigInt       @id @unique @default(autoincrement())
  username      String?
  password      String?
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  neuro         Boolean?
  role          String       @default("USER")
  Phases        Phases[]
  login_metrics UsersLogin[]

  @@map("users")
}

model UsersLogin {
  id         BigInt   @id @unique @default(autoincrement())
  user_id    BigInt
  attempt    BigInt?
  success    Boolean
  phase      Int?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       Users    @relation(fields: [user_id], references: [id])

  @@map("users_login")
}

model Phases {
  id         BigInt   @id @unique @default(autoincrement())
  user_id    BigInt
  completed  Boolean
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       Users    @relation(fields: [user_id], references: [id])

  @@map("phases")
}
